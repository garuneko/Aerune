{
  "name": "aerune",
  "version": "2.5.2",
  "description": "Bluesky Client Aerune",
  "main": "main.js",
  "author": "garu neko",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "dependencies": {
    "@atproto/api": "^0.13.20"
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.garuneko.aerune",
    "productName": "Aerune",
    "directories": {
      "output": "dist"
    },
    "mac": {
  "category": "public.app-category.social-networking",
  "target": ["dmg", "zip"],
  "hardenedRuntime": true,
  "gatekeeperAssess": false,
  "entitlements": "build/entitlements.mac.plist",
  "entitlementsInherit": "build/entitlements.mac.inherit.plist",
  "bundleVersion": "2.5.2"
}
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
